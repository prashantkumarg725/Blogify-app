<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blogify - Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
        }
        .blog-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            cursor: pointer;
        }
        .blog-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }
        .hero-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 60px 0;
            border-radius: 0 0 30px 30px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/"><i class="fas fa-blog me-2"></i>Blogify</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <% if (user) { %>
                        <li class="nav-item"><a class="nav-link" href="/blog/add-new"><i class="fas fa-plus-circle me-1"></i>Add Blog</a></li>
                        <li class="nav-item"><a class="nav-link" href="/user/profile"><i class="fas fa-user-circle me-1"></i><%= user.fullName %></a></li>
                        <li class="nav-item"><a class="nav-link" href="/user/logout"><i class="fas fa-sign-out-alt me-1"></i>Logout</a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link" href="/user/signin"><i class="fas fa-sign-in-alt me-1"></i>Sign In</a></li>
                        <li class="nav-item"><a class="nav-link" href="/user/signup"><i class="fas fa-user-plus me-1"></i>Sign Up</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="hero-section">
        <div class="container text-center">
            <h1 class="display-4 fw-bold mb-3">Welcome to Blogify</h1>
            <p class="lead mb-0">Share your thoughts, stories, and ideas with the world</p>
        </div>
    </div>

    <div class="container my-5">
        <h2 class="mb-4 text-center">Latest Posts</h2>
        <div class="row row-cols-1 row-cols-md-3 g-4">
            <% if (blogs && blogs.length > 0) { %>
                <% blogs.forEach((blog, index) => { %>
                    <div class="col">
                        <div class="card blog-card h-100 shadow-sm" onclick="window.location.href='/blog/<%= blog._id %>'">
                            <img src="<%= blog.coverImageURL || 'https://via.placeholder.com/300x200?text=No+Image' %>" class="card-img-top" style="height: 200px; object-fit: cover;" alt="Blog cover">
                            <div class="card-body">
                                <h5 class="card-title"><%= blog.title %></h5>
                                <p class="card-text text-muted"><small><i class="fas fa-user me-1"></i><%= blog.createdBy ? blog.createdBy.fullName : 'Unknown' %><br><i class="fas fa-clock me-1"></i><%= blog.readingTime || '5 min read' %></small></p>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center"><div class="alert alert-info"><i class="fas fa-info-circle me-2"></i>No blogs yet. Be the first to create one!</div></div>
            <% } %>
        </div>
    </div>

    <footer class="bg-dark text-white text-center py-4 mt-5">
        <div class="container"><p class="mb-0">&copy; 2024 Blogify. All rights reserved.</p></div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>